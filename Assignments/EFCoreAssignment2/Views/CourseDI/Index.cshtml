
@{
    ViewData["Title"] = "Index";
}

@model IEnumerable<Course>

<h2>Courses</h2>

<a asp-action="Create">Add Course</a>

<table border="1">
    <tr>
        <th>Title</th>
        <th>Credits</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Credits</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>


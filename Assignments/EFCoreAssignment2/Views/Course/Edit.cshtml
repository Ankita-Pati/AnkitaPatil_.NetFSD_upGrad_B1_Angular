
@{
    ViewData["Title"] = "Edit";
}

@model Course

<h2>Edit Course</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
    </div>

    <div>
        <label asp-for="Credits"></label>
        <input asp-for="Credits" />
    </div>

    <button type="submit">Update</button>
</form>

<a asp-action="Index">Back</a>


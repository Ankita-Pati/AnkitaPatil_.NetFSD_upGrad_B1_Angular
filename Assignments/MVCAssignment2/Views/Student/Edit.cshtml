@model Student

<h2>Edit Student</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <table border="1">
        <tr>
            <td>Name</td>
            <td><input asp-for="Name" /></td>
        </tr>

        <tr>
            <td>Age</td>
            <td><input asp-for="Age" /></td>
        </tr>

        <tr>
            <td>Email</td>
            <td><input asp-for="Email" /></td>
        </tr>

        <tr>
            <td colspan="2">
                <button type="submit">Update</button>
            </td>
        </tr>
    </table>

</form>
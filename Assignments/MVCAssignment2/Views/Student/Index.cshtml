@* @model Student *@
@model List<Student>
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
    @* <h2>Student Details</h2>
    <p>Name: @Model.Name</p>
    <p>Age: @Model.Age</p>
    <p>Email: @Model.Email</p> *@

    @* Exercise5 *@
    <h2>Student List</h2>

    <a href="/Student/Create">Add New Student</a>

    <table border="1" cellpadding="10">
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
                <td>
                    <a href="/Student/Edit/@item.Id">Edit</a> |
                    <a href="/Student/Delete/@item.Id">Delete</a>
                </td>
            </tr>
        }
    </table>

    @* <h2>Student List</h2>

